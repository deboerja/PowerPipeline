# PowerPipeline does not need credentials for its primary source (SPP public
# data, unauthenticated). These variables configure read-only access to
# existing, already-governed household data produced by other homelab
# pipelines — PowerPipeline never authenticates to Enphase or NWS/IEM itself.
#
# Following the homelab's existing convention
# (~/.config/residentai/<service>.env, mode 600, never git-tracked) — this
# file is a template only. Copy it to a location outside the repo and never
# commit the real values.

# Path to the existing Enphase pipeline's curated output directory (read-only)
POWERPIPELINE_ENPHASE_SNAPSHOTS_DIR=/srv/apps/resident-ai/runtime/snapshots/enphase

# Path to the existing weather pipeline's curated output directory (read-only)
POWERPIPELINE_WEATHER_SNAPSHOTS_DIR=/srv/apps/resident-ai/runtime/snapshots/weather
POWERPIPELINE_WEATHER_STATE_DIR=/srv/apps/resident-ai/runtime/state/latest

# PowerPipeline's own runtime root
POWERPIPELINE_RUNTIME_ROOT=/srv/powerpipeline

# SPP public portal base (no credentials required)
POWERPIPELINE_SPP_PORTAL_BASE=https://portal.spp.org
